<Window x:Class="powerLabel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:powerLabel"
        mc:Ignorable="d"
        Title="powerLabel" Height="500" Width="800">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Left: Scan button + system info -->
        <StackPanel Grid.Column="0" Grid.Row="0" Margin="10" VerticalAlignment="Top">
            <Button x:Name="scanButton" Click="scanButton_Click" Width="100" Height="100">
                <TextBlock TextWrapping="Wrap" FontSize="28" TextAlignment="Center" Text="Scan System"/>
            </Button>

            <Grid x:Name="leftPanelGrid" Visibility="Collapsed" Margin="0,10,0,0">
                <StackPanel>
                    <Label Content="System Info" FontSize="16"/>
                    <TextBlock x:Name="systemInfoText" TextWrapping="Wrap" Width="200"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Right: Label preview + print -->
        <Grid Grid.Column="1" Grid.Row="0" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Label Grid.Row="0" Content="Print Label" FontSize="22"/>

            <Viewbox Grid.Row="1" Margin="5" Stretch="Uniform">
                <Border BorderBrush="#FFD3CFCF" BorderThickness="1" CornerRadius="1">
                    <Grid Name="labelGrid" Width="58" Height="32">
                        <TextBlock FontSize="4" Name="labelText" TextWrapping="WrapWithOverflow" Margin="2"/>
                    </Grid>
                </Border>
            </Viewbox>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                <CheckBox x:Name="boldCheckbox" Content="Bold" VerticalAlignment="Center" Margin="0,0,10,0"
                          Checked="boldCheckbox_Changed" Unchecked="boldCheckbox_Changed"/>
                <Button x:Name="printBtn" Click="printBtn_Click" IsEnabled="False" Width="80" Height="30" Content="Print"/>
            </StackPanel>
        </Grid>

        <!-- Bottom: Settings button -->
        <Button x:Name="settingsBtn" Grid.Column="0" Grid.Row="1" Click="settingsBtn_Click"
                Width="80" Height="30" Margin="10" HorizontalAlignment="Left" Content="Settings"/>
    </Grid>
</Window>
